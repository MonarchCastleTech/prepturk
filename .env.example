# PrepTurk Environment Configuration
# Copy this file to .env and fill in the values

# Application
APP_NAME=prepturk
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=3000
APP_SECRET_KEY=change-this-to-a-secure-random-string
APP_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql+asyncpg://prepturk:prepturk_password@db:5432/prepturk
POSTGRES_USER=prepturk
POSTGRES_PASSWORD=prepturk_password
POSTGRES_DB=prepturk
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=change-this-qdrant-key

# Ollama / AI
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:7b-instruct
OLLAMA_EMBEDDING_MODEL=nomic-embed-text:latest
OPENAI_API_KEY=
OPENAI_BASE_URL=
AI_PROVIDER=ollama

# Storage
STORAGE_ROOT=/app/storage
STORAGE_ORIGINALS=/app/storage/originals
STORAGE_EXTRACTED=/app/storage/extracted
STORAGE_PREVIEWS=/app/storage/previews
STORAGE_THUMBNAILS=/app/storage/thumbnails
STORAGE_VAULT=/app/storage/vault
STORAGE_EXPORTS=/app/storage/exports

# MinIO (optional)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=prepturk
MINIO_USE_SSL=false

# OCR
OCR_ENABLED=false
OCR_LANGUAGE=tur+eng

# Network
LAN_MODE=false
LAN_ALLOWED_IPS=192.168.1.0/24

# Backup
BACKUP_DIR=/app/backups

# Province Packs
PROVINCE_PACKS_DIR=/app/content/manifests/province-packs

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Session
SESSION_MAX_AGE_HOURS=24
SESSION_COOKIE_SECURE=false
